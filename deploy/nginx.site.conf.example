upstream teatralnaya_zavalinka_app {
    server 127.0.0.1:3000;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name tzavalinka.ru teatralzavalinka.ru;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name tzavalinka.ru teatralzavalinka.ru;

    # Пути certbot (после выпуска сертификата)
    ssl_certificate /etc/letsencrypt/live/tzavalinka.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/tzavalinka.ru/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 1512m;

    # Статика загрузок (документы, фото, видео)
    location /uploads/ {
        alias /var/www/teatralnaya-zavalinka/shared/uploads/;
        access_log off;
        expires 7d;
        add_header Cache-Control "public";
        try_files $uri =404;
    }

    # Админ API
    location /api/admin/ {
        proxy_pass http://teatralnaya_zavalinka_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Админка
    location /admin {
        proxy_pass http://teatralnaya_zavalinka_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Публичные страницы и ассеты
    location / {
        proxy_pass http://teatralnaya_zavalinka_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
